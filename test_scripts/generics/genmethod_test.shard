using stdio;

namespace hello_world;

public static func Identity<T>(x: T) -> T
{
    return x;
}

public static func Max<T>(a: T, b: T) -> T
{
    if (a > b)
        return a;
    return b;
}

public static func Main() -> void
{
    print(Identity<int>(5));
    println("");
    print(Identity<string>("hello"));
    println("");
    print(Max<int>(3, 7));
    println("");
}

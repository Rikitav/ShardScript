using stdio;

namespace hello_world;

public class List<T>
{
    private count: int;

    public func Add(item: T) -> void
    {
        this.count = this.count + 1;
    }

    public func GetCount() -> int
    {
        return this.count;
    }
}

public static func CreateList<T>() -> List<T>
{
    return new List<T>();
}

public static func Main() -> void
{
    list := CreateList<string>();
    list.Add("hello");
    println(list.GetCount());
}

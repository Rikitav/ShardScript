using stdio;

namespace hello_world;

public class Container<T>
{
    public Value: T;
}

public static func Main() -> void
{
    outer: Container<Container<int>> = new Container<Container<int>>();
    inner: Container<int> = new Container<int>();
    inner.Value = 99;
    outer.Value = inner;
    println(outer.Value.Value);
}

using stdio;
using collections;

namespace hello_world;

public static func Main() -> void
{
    list: List<int> = new List<int>();
    list.Add(7);
    list.Add(8);

    enumerable: IEnumerable<int> = list;
    foreach (n in enumerable)
    {
        print(n);
        print(" ");
    }
    println("");
}

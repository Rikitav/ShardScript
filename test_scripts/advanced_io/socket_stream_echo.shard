using stdio;
using async;
using net;

namespace socket_stream_echo_test;

public class Program
{
    public static async func RunEchoServer(port: int, done: TaskCompletionSource<int>) -> Task
    {
        server := new Socket();
        defer server.Dispose();

        if (!server.Bind("127.0.0.1", port))
        {
            println("Failed to bind echo server");
            throw new RuntimeException();
        }

        if (!server.Listen(1))
        {
            println("Failed to listen");
            throw new RuntimeException();
        }

        client := await server.AcceptAsync();
        defer client.Dispose();

        stream := new SocketStream(client);
        defer stream.Dispose();

        buffer: byte[] = [0 as byte, 0 as byte, 0 as byte, 0 as byte, 0 as byte];
        read := await stream.ReadAsync(buffer, 0, 5);
        if (read != 5)
        {
            println("Server expected 5 bytes, got " + read);
            throw new RuntimeException();
        }

        await stream.WriteAsync(buffer, 0, read);
        done.SetResult(0);
    }

    public static async func RunClient() -> Task
    {
        port := 17654;
        done := new TaskCompletionSource<int>();

        serverTask := RunEchoServer(port, done);

        // Give the server a moment to start listening.
        await Task.Delay(50);

        client := new Socket();
        defer client.Dispose();

        if (!client.Connect("127.0.0.1", port))
        {
            println("Failed to connect echo client");
            throw new RuntimeException();
        }

        stream := new SocketStream(client);
        defer stream.Dispose();

        input: byte[] = [72 as byte, 101 as byte, 108 as byte, 108 as byte, 111 as byte];
        await stream.WriteAsync(input, 0, 5);

        buffer: byte[] = [0 as byte, 0 as byte, 0 as byte, 0 as byte, 0 as byte];
        read := await stream.ReadAsync(buffer, 0, 5);
        if (read != 5)
        {
            println("Client expected 5 bytes, got " + read);
            throw new RuntimeException();
        }

        for (i := 0; i < 5; i = i + 1)
        {
            if (buffer[i] != input[i])
            {
                println("Echo mismatch at " + i);
                throw new RuntimeException();
            }
        }

        // Wait for the server side to finish cleanly.
        await done.Task;
        await serverTask;

        println("socket stream echo ok");
    }

    public static func Main() -> void
    {
        task := RunClient();
        Task.Wait(task);
    }
}

using stdio;
using async;
using net;

namespace socket_stream_cancellation_test;

public class Program
{
    public static async func Run() -> Task
    {
        port := 17655;

        server := new Socket();
        defer server.Dispose();

        if (!server.Bind("127.0.0.1", port))
        {
            println("Failed to bind cancellation server");
            throw new RuntimeException();
        }

        if (!server.Listen(1))
        {
            println("Failed to listen");
            throw new RuntimeException();
        }

        client := new Socket();
        defer client.Dispose();

        if (!client.Connect("127.0.0.1", port))
        {
            println("Failed to connect cancellation client");
            throw new RuntimeException();
        }

        serverClient := server.Accept();
        defer serverClient.Dispose();

        stream := new SocketStream(client);
        defer stream.Dispose();

        cts := new CancellationTokenSource();
        token := cts.Token;

        // Cancel before the async read starts.
        cts.Cancel();

        buffer: byte[] = [0 as byte, 0 as byte, 0 as byte, 0 as byte, 0 as byte];
        try
        {
            await stream.ReadAsync(buffer, 0, 5, token);
            println("Expected cancellation exception");
            throw new RuntimeException();
        }
        catch (ex: RuntimeException)
        {
            println("canceled socket read threw: " + ex.message);
        }

        println("socket stream cancellation ok");
    }

    public static func Main() -> void
    {
        task := Run();
        Task.Wait(task);
    }
}

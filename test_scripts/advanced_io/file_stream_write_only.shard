using stdio;
using async;
using filesystem;

namespace file_stream_write_only_test;

public class Program
{
    public static async func Run() -> Task
    {
        path := "D:/temp/shard_file_stream_write_only.bin";
        if (File.Exists(path))
            File.Delete(path);

        fs := new FileStream(path, FileMode.CreateNew, FileAccess.Write);
        input: byte[] = [1 as byte, 2 as byte, 3 as byte];
        await fs.WriteAsync(input, 0, 3);
        fs.Dispose();

        println("write only ok");
    }

    public static func Main() -> void
    {
        task := Run();
        Task.Wait(task);
    }
}

using net;

namespace socket_client;

public static func Main() -> void
{
	defer server: Socket = new Socket();
	if (!server.Bind("127.0.0.1", 6969))
	{
        println("Failed to bind socket");
        return;
    }

    if (!server.Listen(-1))
    {
        println("Failed to listen");
        return;
    }

    println("Server is listening on port 6969. Awaiting clients...");
    while (true)
    {
        defer client := server.Accept();
        if (client == null)
            continue;

        println("Client connected! Receiving message...");
        msg := client.Receive(1024);
        println("Received : " + msg);
    }
}

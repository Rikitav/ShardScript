using stdio;

namespace hello_world;

public class A
{
    public x: int;

    public static operator +(a: A, b: A) -> int
    {
        return a.x + b.x;
    }
}

public static func Main() -> void
{
    a1: A = new A();
    a1.x = 2;
    a2: A = new A();
    a2.x = 3;
    print(a1 + a2);
    println("");
}

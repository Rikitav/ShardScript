using Database;
using stdio;

namespace sqlite_test;

public static func Main() -> void
{
    defer conn: SqliteConnection = new SqliteConnection(":memory:");

    print("SQLite version: ");
    println(SqliteConnection.Version);

    literal := conn.ExecuteScalar("SELECT 'hello';");
    print("Literal: ");
    println(literal as string);

    conn.ExecuteNonQuery("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT);");
    conn.ExecuteNonQuery("INSERT INTO users (name) VALUES ('Alice');");
    conn.ExecuteNonQuery("INSERT INTO users (name) VALUES ('Bob');");

    name := conn.ExecuteScalar("SELECT name FROM users WHERE id = 1;");
    print("User #1: ");
    println(name as string);

    count := conn.ExecuteScalar("SELECT COUNT(*) FROM users;");
    print("Total users: ");
    println(count as int);
}

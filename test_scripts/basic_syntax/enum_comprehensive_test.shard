using stdio;

namespace enum_comprehensive_test;

public enum Color
{
    Red,
    Green,
    Blue
}

public static func GetColorName(c: Color) -> string
{
    return c.ToString();
}

public static func Main() -> void
{
    c: Color = Color.Red;
    print(GetColorName(c));
    println("");

    print(c == Color.Red);
    println("");

    print(c == Color.Green);
    println("");
}

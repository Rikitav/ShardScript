using stdio;

namespace operator_test;

public class Box
{
    public Value: int;

    public init(val: int)
    {
        this.Value = val;
    }

    public static operator +(a: Box, b: Box) -> int
    {
        return a.Value + b.Value;
    }
}

public static func Main() -> void
{
    a: Box = new Box(2);
    b: Box = new Box(1);
    c: int = a + b;
    println(c);
}

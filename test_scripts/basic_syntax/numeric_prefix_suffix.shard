using stdio;

namespace hello_world;

public static func Main() -> void
{
    hex: int = 0xA1;
    binary: int = 0b1010;
    decimalPrefix: int = 0d42;
    mb: int = 2MB;
    gb: int = 0x14GB;

    if (hex == 161)
        println("hex ok");

    if (binary == 10)
        println("binary ok");

    if (decimalPrefix == 42)
        println("decimal prefix ok");

    if (mb == 2 * 1024 * 1024)
        println("mb ok");

    if (gb == 20 * 1024 * 1024 * 1024)
        println("gb ok");
}

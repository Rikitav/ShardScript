using stdio;

namespace hello_world;

public static func Main() -> void
{
    plain: int = 42;
    separated: int = 1`000`000;
    large: int = 1234567890;

    if (separated == 1000000)
        println("separated ok");

    if (plain + separated == 1000042)
        println("sum ok");

    if (large > separated)
        println("large ok");
}

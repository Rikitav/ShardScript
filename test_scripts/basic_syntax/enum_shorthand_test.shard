using stdio;

namespace enum_shorthand_test;

public enum Permissions : flags { Read, Write, Execute }

public static class Program
{
    public static func Main() -> void
    {
        a: Permissions = Permissions.Read | Write;
        b: Permissions = Read | Permissions.Write;
        c: Permissions = Permissions.Read | Write | Execute;

        println(a.ToString());
        println(b.ToString());
        println(c.ToString());

        if (a.HasFlag(Permissions.Write))
            println("has Write");

        if (c.HasFlag(Permissions.Execute))
            println("has Execute");

        d: Permissions = Write;
        println(d.ToString());
    }
}

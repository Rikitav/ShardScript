using stdio;
using collections;

namespace hello_world;

public static func Main() -> void
{
    foreach (x in 1..5)
    {
        print(x);
        print(" ");
    }
    println("");

    list: List<int> = new List<int>();
    list.Add(10);
    list.Add(20);
    list.Add(30);

    foreach (n in list)
    {
        print(n);
        print(" ");
    }
    println("");
}

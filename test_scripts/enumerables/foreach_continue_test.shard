using stdio;
using collections;

namespace hello_world;

public static func Main() -> void
{
    list: List<int> = new List<int>();
    list.Add(1);
    list.Add(2);
    list.Add(3);
    list.Add(4);

    foreach (n in list)
    {
        if (n == 2)
            continue;
        print(n);
        print(" ");
    }
    println("");
}

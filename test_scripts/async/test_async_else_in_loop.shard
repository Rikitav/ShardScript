using stdio;
using async;

namespace test_async_else_in_loop;

public class Program
{
    public static func Main() -> void
    {
        task := DoItAsync();
        Task.Wait(task);
    }

    public static async func DoItAsync() -> Task
    {
        i := 0;
        while (i < 4)
        {
            if (i % 2 == 0)
            {
                println("even");
            }
            else
            {
                println("odd before");
                await Task.Delay(1);
                println("odd after");
            }

            i = i + 1;
        }

        println("done");
    }
}

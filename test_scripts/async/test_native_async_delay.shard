using stdio;
using async;

namespace test_native_async_delay;

public class Program
{
    public static async func DelayedHello() -> Task
    {
        println("before");
        await NativeAsyncTests.Delay(50);
        println("after");
    }

    public static func Main() -> void
    {
        Task.Wait(DelayedHello());
    }
}

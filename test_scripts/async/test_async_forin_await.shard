using stdio;
using async;

namespace test_async_forin_await;

public class Program
{
    public static func Main() -> void
    {
        task := DoItAsync();
        Task.Wait(task);
    }

    public static async func DoItAsync() -> Task
    {
        arr := [1, 2, 3];
        for (x in arr)
        {
            println(x);
            await Task.Delay(100);
        }

        println("done");
    }
}

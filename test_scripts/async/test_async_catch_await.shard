using stdio;
using async;

namespace test_async_catch_await;

public class Program
{
    public static async func FaultyDelay() -> Task
    {
        await Task.Delay(10);
        throw new RuntimeException();
    }

    public static async func CaughtAwait() -> Task
    {
        try
        {
            await FaultyDelay();
        }
        catch (ex: RuntimeException)
        {
            println("caught before await");
            await Task.Delay(10);
            println("caught after await");
            exCopy := ex;
            println(exCopy.message);
            println("ok");
        }

        println("after catch");
    }

    public static func Main() -> void
    {
        Task.Wait(CaughtAwait());
        println("done");
    }
}

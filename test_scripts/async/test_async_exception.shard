using stdio;
using async;

namespace test_async_exception;

public class Program
{
    public static async func ThrowBeforeAwait() -> Task
    {
        println("before throw");
        throw new RuntimeException();
        println("after throw");
    }

    public static func Main() -> void
    {
        try
        {
            Task.Wait(ThrowBeforeAwait());
            println("unreachable");
        }
        catch (ex: RuntimeException)
        {
            println("caught");
        }
        println("done");
    }
}

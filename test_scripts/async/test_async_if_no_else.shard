using stdio;
using async;

namespace test_async_if_no_else;

public class Program
{
    public static func Main() -> void
    {
        task := DoItAsync();
        Task.Wait(task);
    }

    public static async func DoItAsync() -> Task
    {
        println("start");
        if (true)
        {
            println("yes");
        }
        println("end");
    }
}

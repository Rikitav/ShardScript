using stdio;
using async;

namespace test_async_await_int_var;

public class Program
{
    public static async func GetIntAsync() -> ValueTask<int>
    {
        await Task.Delay(10);
        return 42;
    }

    public static func Main() -> void
    {
        task := DoItAsync();
        Task.Wait(task);
    }

    public static async func DoItAsync() -> Task
    {
        n := await GetIntAsync();
        println(n);
    }
}

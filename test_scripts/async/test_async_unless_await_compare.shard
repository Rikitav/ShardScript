using stdio;
using async;

namespace test_async_unless_await_compare;

public class Program
{
    public static async func GetBoolAsync() -> ValueTask<bool>
    {
        await Task.Delay(10);
        return true;
    }

    public static func Main() -> void
    {
        task := DoItAsync();
        ValueTask.Wait(task);
    }

    public static async func DoItAsync() -> Task
    {
        unless (await GetBoolAsync() == false)
        {
            println("yes");
        }
        else
        {
            println("no");
        }
    }
}

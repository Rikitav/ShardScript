using stdio;
using async;

namespace test_async_defer_return;

public class Program
{
    public static async func WorkAsync() -> Task
    {
        defer println("deferred");
        println("before await");
        await Task.Delay(10);
        println("after await");
        return;
    }

    public static func Main() -> void
    {
        Task.Wait(WorkAsync());
        println("done");
    }
}
